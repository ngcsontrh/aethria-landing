---
import Layout from '../layouts/Layout.astro';
import LandingPage from '../components/LandingPage.astro';

export function getStaticPaths() {
	return [
		{ params: { lang: 'en' } },
		{ params: { lang: 'vi' } },
	];
}

const lang = Astro.params.lang === 'vi' ? 'vi' : 'en';
---

<Layout lang={lang}>
	<LandingPage lang={lang} />
</Layout>
