---
const chatUrl = import.meta.env.PUBLIC_CHAT_URL;
const {
  lang = 'en',
} = Astro.props;

const isVi = lang === 'vi';

const copy = isVi ? {
  headline: 'Nền Tảng Học Tập Hỗ Trợ Bởi AI Giúp',
  headlineAccent: 'Học Thông Minh Hơn',
  description: 'Tải lên tài liệu học tập, tự động tạo lộ trình cá nhân hóa, ôn luyện với đề trắc nghiệm AI và tương tác với các cố vấn ảo để làm chủ mọi kiến thức.',
  primaryCta: 'Bắt đầu miễn phí',
  secondaryCta: 'Tìm hiểu thêm',
  chatGuidance: 'Hướng dẫn Chat',
  roadmaps: 'Lộ trình học',
  quizzes: 'Đề trắc nghiệm',
  mentors: 'Người hướng dẫn',
  guideTitle: 'Hướng dẫn học tập — Cố vấn AI',
  active: 'Đang hoạt động',
  greetingPrefix: 'Xin chào! Tôi đã nạp tài liệu giáo trình ',
  bookTitle: '"Hệ cơ sở dữ liệu"',
  greetingSuffix: ' của bạn. Chúng ta nên bắt đầu tìm hiểu chủ đề nào?',
  question: 'Bạn giải giải thích Dạng chuẩn 3 (3NF) một cách đơn giản và vẽ sơ đồ minh họa được không?',
  answerPrefix: 'Một quan hệ đạt ',
  answerSuffix: ' nếu mọi thuộc tính không khóa phụ thuộc trực tiếp ',
  answerEmphasis: 'chỉ',
  answerEnd: ' vào khóa chính.',
  placeholder: 'Hỏi cố vấn AI của bạn...',
} : {
  headline: 'AI-Assisted Learning Platform for',
  headlineAccent: 'Smarter Study',
  description: 'Upload study documents, auto-generate interactive roadmaps, practice with custom quizzes, and chat with AI-guided mentor agents to master any subject.',
  primaryCta: 'Get Started Free',
  secondaryCta: 'Learn More',
  chatGuidance: 'Chat guidance',
  roadmaps: 'Roadmaps',
  quizzes: 'Quizzes',
  mentors: 'Mentors',
  guideTitle: 'Study Guide — AI Mentor',
  active: 'Active',
  greetingPrefix: "Hello! I've loaded your textbook ",
  bookTitle: '"Introduction to Database Systems"',
  greetingSuffix: '. What topic should we explore?',
  question: 'Can you explain Third Normal Form (3NF) simply and show a diagram?',
  answerPrefix: 'A relation is in ',
  answerSuffix: ' if every non-key attribute depends ',
  answerEmphasis: 'only',
  answerEnd: ' on the primary key.',
  placeholder: 'Ask your AI mentor...',
};
---

<section class="relative w-full py-16 lg:py-24 px-6 overflow-hidden bg-gradient-to-b from-indigo-50/50 via-sky-50/40 to-white dark:from-bg-dark-secondary dark:to-bg-dark-primary border-b border-slate-100 dark:border-slate-800/50 transition-colors duration-300">
  <!-- Ambient glow layers create depth without affecting layout or interactions. -->
  <div class="absolute w-[450px] h-[450px] rounded-full bg-indigo-400/18 dark:bg-indigo-500/10 blur-[120px] top-[10%] -left-[10%] pointer-events-none animate-pulse" style="animation-duration: 8s;"></div>
  <div class="absolute w-[400px] h-[400px] rounded-full bg-sky-400/22 dark:bg-sky-500/10 blur-[120px] bottom-[10%] -right-[10%] pointer-events-none animate-pulse" style="animation-duration: 12s;"></div>
  <div class="absolute w-[350px] h-[350px] rounded-full bg-violet-400/12 dark:bg-violet-500/8 blur-[100px] top-[40%] right-[30%] pointer-events-none animate-pulse" style="animation-duration: 10s;"></div>

  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-[1.10fr_1fr] gap-12 lg:gap-16 items-center relative z-10">
    <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
      <h1 class="font-sans text-4xl sm:text-5xl lg:text-5xl font-extrabold tracking-tight leading-tight text-slate-900 dark:text-white mb-6">
        {copy.headline} <span class="bg-gradient-to-r from-indigo-500 via-violet-500 to-sky-500 bg-clip-text text-transparent">{copy.headlineAccent}</span>
      </h1>

      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 mb-8 max-w-lg leading-relaxed">
        {copy.description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a href={chatUrl} class="px-6 py-3.5 rounded-lg bg-gradient-to-r from-indigo-500 via-violet-500 to-sky-500 hover:brightness-105 active:scale-[0.98] text-sm font-semibold text-white shadow-md hover:shadow-lg hover:shadow-indigo-500/20 flex items-center gap-2 justify-center transition-all duration-300 group no-underline">
          <span>{copy.primaryCta}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a href="#features" class="px-6 py-3.5 rounded-lg bg-white hover:bg-slate-50 dark:bg-slate-800/40 dark:hover:bg-slate-800/80 text-sm font-semibold text-slate-800 dark:text-slate-200 border border-slate-200 dark:border-slate-800/80 flex items-center gap-2 justify-center transition-all no-underline">
          <span>{copy.secondaryCta}</span>
        </a>
      </div>
    </div>

    <div class="w-full lg:scale-100 transform hover:scale-[1.01] transition-transform duration-300 shadow-2xl">
      <div class="w-full rounded-xl bg-white dark:bg-bg-dark-secondary border border-slate-200 dark:border-slate-800/80 overflow-hidden">
        <div class="h-10 bg-slate-100/80 dark:bg-slate-900/60 border-b border-slate-200 dark:border-slate-800/80 grid grid-cols-[80px_1fr_80px] items-center px-4">
          <div class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
          </div>
          <div class="bg-slate-200/50 dark:bg-slate-950/40 border border-slate-300/40 dark:border-slate-800/50 text-[10px] text-slate-500 dark:text-slate-400 font-mono text-center rounded py-0.5">
            chat.aethria.study
          </div>
          <div></div>
        </div>

        <div class="grid grid-cols-[140px_1fr] h-[320px] bg-slate-50/50 dark:bg-bg-dark-primary/40">
          <aside class="bg-slate-100/30 dark:bg-bg-dark-secondary/50 border-r border-slate-200 dark:border-slate-800/80 p-3 flex flex-col gap-5">
            <div class="flex items-center gap-2 px-1 text-slate-800 dark:text-slate-200 font-bold text-xs">
              <img src="/logo-icon.png" alt="" class="w-4 h-4" />
              <span>Aethria</span>
            </div>
            <nav class="flex flex-col gap-1">
              <div class="flex items-center gap-2 px-2.5 py-1.5 text-[10px] font-medium rounded-md cursor-default bg-indigo-50 dark:bg-brand-primary/10 text-indigo-600 dark:text-white">
                <span>💬</span>
                <span>{copy.chatGuidance}</span>
              </div>
              <div class="flex items-center gap-2 px-2.5 py-1.5 text-[10px] font-medium text-slate-500 dark:text-slate-400 rounded-md cursor-default">
                <span>🗺️</span>
                <span>{copy.roadmaps}</span>
              </div>
              <div class="flex items-center gap-2 px-2.5 py-1.5 text-[10px] font-medium text-slate-500 dark:text-slate-400 rounded-md cursor-default">
                <span>📝</span>
                <span>{copy.quizzes}</span>
              </div>
              <div class="flex items-center gap-2 px-2.5 py-1.5 text-[10px] font-medium text-slate-500 dark:text-slate-400 rounded-md cursor-default">
                <span>🧑‍🏫</span>
                <span>{copy.mentors}</span>
              </div>
            </nav>
          </aside>

          <main class="flex flex-col bg-slate-50/20 dark:bg-bg-dark-primary/20">
            <div class="h-11 border-b border-slate-200 dark:border-slate-800/80 flex items-center justify-between px-4">
              <h3 class="text-[10px] font-bold text-slate-800 dark:text-slate-200">
                {copy.guideTitle}
              </h3>
              <span class="flex items-center gap-1.5 text-[9px] font-medium bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400 px-2 py-0.5 rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                {copy.active}
              </span>
            </div>

            <div class="flex-1 p-4 overflow-y-auto flex flex-col justify-end">
              <div class="flex flex-col gap-3">
                <div class="flex gap-2 items-start max-w-[85%] self-start">
                  <div class="w-5 h-5 rounded-full bg-slate-200 dark:bg-slate-800 text-[10px] flex items-center justify-center">🤖</div>
                  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800/80 p-2.5 rounded-lg text-[10px] text-slate-700 dark:text-slate-300 leading-relaxed shadow-sm">
                    <p>{copy.greetingPrefix}<strong>{copy.bookTitle}</strong>{copy.greetingSuffix}</p>
                  </div>
                </div>

                <div class="flex gap-2 items-start max-w-[85%] self-end">
                  <div class="bg-indigo-50 dark:bg-brand-primary/10 border border-indigo-100 dark:border-brand-primary/20 p-2.5 rounded-lg text-[10px] text-indigo-900 dark:text-slate-100 leading-relaxed shadow-sm">
                    <p>{copy.question}</p>
                  </div>
                  <div class="w-5 h-5 rounded-full bg-gradient-to-r from-indigo-500 via-violet-500 to-sky-500 text-white text-[10px] flex items-center justify-center">👤</div>
                </div>

                <div class="flex gap-2 items-start max-w-[85%] self-start">
                  <div class="w-5 h-5 rounded-full bg-slate-200 dark:bg-slate-800 text-[10px] flex items-center justify-center">🤖</div>
                  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800/80 p-2.5 rounded-lg text-[10px] text-slate-700 dark:text-slate-300 leading-relaxed shadow-sm">
                    <p>{copy.answerPrefix}<strong>3NF</strong>{copy.answerSuffix}<strong>{copy.answerEmphasis}</strong>{copy.answerEnd}</p>
                    <div class="mt-2 p-1.5 bg-slate-100 dark:bg-slate-950 border border-slate-200 dark:border-slate-800/80 rounded font-mono text-[8px] text-slate-600 dark:text-slate-400">
                      <div class="flex justify-between items-center text-red-500 dark:text-red-400">
                        <span>PK [ID] &rarr; Attribute A &rarr; Attribute B</span>
                        <span class="bg-red-50 dark:bg-red-950/30 px-1 rounded text-[7px] font-bold">Transitive: Bad</span>
                      </div>
                      <div class="flex justify-between items-center text-emerald-500 dark:text-emerald-400 mt-1">
                        <span>PK [ID] &rarr; A • PK [A] &rarr; B</span>
                        <span class="bg-emerald-50 dark:bg-emerald-950/30 px-1 rounded text-[7px] font-bold">3NF: OK</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="h-10 border-t border-slate-200 dark:border-slate-800/80 flex items-center px-3 gap-2 bg-slate-100/40 dark:bg-slate-900/30">
              <span class="text-xs opacity-50 cursor-default">📎</span>
              <div class="flex-1 text-[10px] text-slate-400 dark:text-slate-500">
                <span>{copy.placeholder}</span>
              </div>
              <span class="text-xs opacity-50 cursor-default">⚡</span>
            </div>
          </main>
        </div>
      </div>
    </div>
  </div>
</section>
